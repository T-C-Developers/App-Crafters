<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:padding="24dp">

<!-- Profile Picture Preview -->
<ImageView
    android:id="@+id/imageProfile"
    android:layout_width="120dp"
    android:layout_height="120dp"
    android:src="@drawable/img_profile"
    android:contentDescription="Profile Picture"
    android:scaleType="centerCrop"
    android:background="@drawable/circle_background"
    android:clickable="true"
    android:focusable="true"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

<!-- Select Profile Picture (Optional) -->
<TextView
    android:id="@+id/tvSelectImage"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Select Profile Picture (Optional)"
    android:textColor="?attr/colorPrimary"
    android:textSize="14sp"
    android:layout_marginTop="8dp"
    app:layout_constraintTop_toBottomOf="@id/imageProfile"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

<!-- Display Name (Required) -->
<EditText
    android:id="@+id/etDisplayName"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:hint="Display Name"
    android:inputType="textPersonName"
    android:maxLines="1"
    android:layout_marginTop="32dp"
    app:layout_constraintTop_toBottomOf="@id/tvSelectImage"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

<!-- Save Button -->
<Button
    android:id="@+id/btnSaveProfile"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="Save"
    android:layout_marginTop="24dp"
    app:layout_constraintTop_toBottomOf="@id/etDisplayName"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
